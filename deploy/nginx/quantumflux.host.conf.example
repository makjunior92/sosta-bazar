# Add inside your quantumflux.cloud HTTPS server block.
# Sosta Bazar stack must listen on 127.0.0.1:9080 (see docker-compose.prod.yml).

location = /sostabazar {
    return 301 /sostabazar/;
}

location /sostabazar/ {
    proxy_pass http://127.0.0.1:9080/sostabazar/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 300s;
}
